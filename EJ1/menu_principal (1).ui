  <property name="styleSheet">
   <string notr="true">/* =========================
   GLOBAL
   ========================= */
QMainWindow {
    background-color: #f4f8f6;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 8pt;
    color: #2f3e34;
}

/* =========================
   MENU BAR
   ========================= */
QMenuBar {
    background-color: #e8f3ec;
    border-bottom: 1px solid #c8ded2;
}

QMenuBar::item {
    background: transparent;
    padding: 4px 10px;
    margin: 2px;
}

QMenuBar::item:selected {
    background-color: #cfe9da;
    border-radius: 4px;
}

/* =========================
   MENUS
   ========================= */
QMenu {
    background-color: #ffffff;
    border: 1px solid #c8ded2;
    padding: 4px;
}

QMenu::item {
    padding: 6px 20px;
    border-radius: 4px;
}

QMenu::item:selected {
    background-color: #d9efe3;
}

/* =========================
   LABELS
   ========================= */
QLabel {
    color: #3c4f45;
}

/* =========================
   INPUTS
   ========================= */
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #c8ded2;
    border-radius: 5px;
    padding: 4px 6px;
}

QLineEdit:focus {
    border: 1px solid #6fbf9f;
}

/* =========================
   BUTTONS
   ========================= */
QPushButton {
    background-color: #6fbf9f;
    color: white;
    border: none;
    border-radius: 5px;
    padding: 5px 10px;
    min-height: 20px;
}

QPushButton:hover {
    background-color: #5aa98c;
}

QPushButton:pressed {
    background-color: #4a9077;
}

QPushButton:disabled {
    background-color: #c7dcd3;
    color: #7a8f86;
}

/* =========================
   STATUS BAR (opcional)
   ========================= */
QStatusBar {
    background-color: #e8f3ec;
    border-top: 1px solid #c8ded2;
}</string>
